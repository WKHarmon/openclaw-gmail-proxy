# ─── Secrets backend: Vault (recommended) ────────────────────────────────────
# If VAULT_ROLE_ID and VAULT_SECRET_ID are set, secrets are read from Vault.
# VAULT_ADDR=https://vault.your-domain.com:8200
# VAULT_ROLE_ID=your-approle-role-id-here
# VAULT_SECRET_ID=your-approle-secret-id-here

# ─── Secrets backend: Environment variables (alternative) ────────────────────
# If Vault is not configured, set these directly:
# API_KEY=your-api-key-here
# GMAIL_CLIENT_ID=your-google-oauth-client-id
# GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
# GMAIL_REFRESH_TOKEN=your-google-oauth-refresh-token
# GMAIL_ACCESS_TOKEN=
# CF_ACCESS_CLIENT_ID=your-cloudflare-access-client-id
# CF_ACCESS_CLIENT_SECRET=your-cloudflare-access-client-secret
# CALLBACK_HOOKS_TOKEN=your-hooks-bearer-token

# ─── Optional ────────────────────────────────────────────────────────────────
# Token for authenticating Signal webhook callbacks (must match signal.webhook_token in config.json)
# SIGNAL_WEBHOOK_TOKEN=
