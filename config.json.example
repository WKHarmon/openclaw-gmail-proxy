{
  "port": 18795,
  "gmail_account": "user@example.com",
  "vault_path": "secret/authorization-gateway",
  "approver_name": "Approver",
  "signal": {
    "api_url": "http://signal-api:8080",
    "sender": "+1XXXXXXXXXX",
    "approver": "+1YYYYYYYYYY",
    "webhook_token": ""
  },
  "approval_url_base": "https://approval.your-domain.com",
  "requestors": {
    "YourAgent": {
      "api_key_vault_path": "secret/agent/authorization-gateway",
      "callback": {
        "url": "https://your-agent-domain.com/hooks/grant-callback",
        "cf_auth": true,
        "hooks_token_vault_path": "secret/agent/gateway"
      }
    },
    "AnotherAgent": {
      "api_key_vault_path": "secret/another-agent/authorization-gateway",
      "callback": null
    }
  },
  "rate_limit": {
    "grant_requests_per_minute": 5
  },
  "defaults": {
    "level1_expiry_minutes": 5,
    "level2_default_duration_minutes": 30,
    "level3_default_duration_minutes": 15
  },
  "sensitive_patterns_file": "sensitive_patterns.json",
  "providers": {
    "ssh": {
      "enabled": false,
      "vault_ssh_mount": "ssh-client-signer",
      "vault_ssh_role": "agent",
      "default_ttl_minutes": 30,
      "max_ttl_minutes": 30,
      "hosts": {
        "server": {
          "hostnames": ["server", "server.local", "server.wkharmon.com", "server.tailc05c6.ts.net"],
          "principals": ["pi", "user", "kyle", "admin", "root", "agent", "claude"],
          "description": "Primary server"
        },
        "aiserver": {
          "hostnames": ["aiserver", "aiserver.local", "aiserver.wkharmon.com", "aiserver.tailc05c6.ts.net"],
          "principals": ["pi", "user", "kyle", "admin", "root", "agent", "claude"],
          "description": "AI server"
        },
        "wkh-gaming": {
          "hostnames": ["wkh-gaming", "wkh-gaming.local", "wkh-gaming.wkharmon.com", "wkh-gaming.tailc05c6.ts.net"],
          "principals": ["pi", "user", "kyle", "wkhar", "admin", "root", "agent", "claude"],
          "description": "Gaming PC"
        },
        "agent": {
          "hostnames": ["agent", "agent.local", "agent.wkharmon.com", "agent.tailc05c6.ts.net"],
          "principals": ["pi", "user", "kyle", "admin", "root", "agent", "claude"],
          "description": "Agent server"
        },
        "spark": {
          "hostnames": ["spark", "spark.wkharmon.com", "spark-wifi.wkharmon.com"],
          "principals": ["pi", "user", "kyle", "admin", "root", "agent", "claude"],
          "description": "Spark"
        },
        "vault": {
          "hostnames": ["vault", "vault.local", "vault.wkharmon.com", "vault.tailc05c6.ts.net", "secrets", "secrets.local", "secrets.wkharmon.com", "secrets.tailc05c6.ts.net"],
          "principals": ["pi", "user", "kyle", "admin", "root", "agent", "claude"],
          "description": "Vault / secrets server"
        }
      },
      "host_groups": {},
      "defaults": {
        "level1_ttl_minutes": 30,
        "level2_ttl_minutes": 30,
        "level3_ttl_minutes": 30
      }
    }
  }
}
